# ===========================================
# FinVault Monorepo — .gitignore
# Covers: Java/Spring Boot + Angular/Node
# ===========================================

# -----------------------------------------------
# Node / Angular (frontend/)
# -----------------------------------------------
node_modules/
dist/
.angular/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------
# Java / Maven (backend/)
# -----------------------------------------------
*.class
*.jar
*.war
*.nar
*.ear
target/
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# -----------------------------------------------
# Logs
# -----------------------------------------------
*.log
logs/
*.log.*

# -----------------------------------------------
# IDE / OS
# -----------------------------------------------
.idea/
*.iml
*.iws
.DS_Store
Thumbs.db

# -----------------------------------------------
# Misc Java
# -----------------------------------------------
*.ctxt
.mtj.tmp/
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*
